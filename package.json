{
  "name": "genfinds",
  "version": "2.0.0",
  "description": "Aplicativo de finanças pessoais multiplataforma — Desktop e Mobile",
  "main": "dist-electron/main/index.js",
  "author": "Kassiano Vieira <kassianovieira.pc@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e",
    "build:desktop": "npm run build && electron-builder",
    "build:android": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "build:android:release": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "clean": "rimraf dist dist-electron release coverage"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fastify/cors": "^11.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.11.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.4.3",
    "fastify": "^5.8.5",
    "hash-wasm": "^4.11.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.77.0",
    "react-qr-code": "^2.2.0",
    "react-router-dom": "^7.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^2.14.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^2.6.0",
    "winston": "^3.17.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  }
}
