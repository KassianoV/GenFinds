{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron/**/*",
    "src/types/**/*",
    "electron-builder.config.ts",
    "electron.vite.config.ts",
    "capacitor.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "paths": {
      "@electron/*": ["./electron/*"]
    }
  }
}
