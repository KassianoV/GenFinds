{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/**/*", "src/types/**/*", "src/env.d.ts"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@renderer/*": ["./src/renderer/*"]
    }
  }
}
